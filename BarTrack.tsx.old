const generateSeedData = (): AppStore => {
  const now = Date.now()
  const drinks: Drink[] = INITIAL_DRINKS_SEED.map((d, i) => ({
    ...d,
    id: uid(),
    createdAt: new Date(now - (INITIAL_DRINKS_SEED.length - i) * 60000).toISOString()
  }))

  const sessions: DailySession[] = []
  const expenses: Expense[] = []

  // Generate 14 days of sessions
  for (let i = 13; i >= 0; i--) {
    const sessionDate = new Date()
    sessionDate.setDate(sessionDate.getDate() - i)
    const dateStr = sessionDate.toISOString().split('T')[0]

    const lines: SessionLine[] = drinks.map(drink => {
      const salesFactor = Math.random() * 0.3
      const sold = Math.max(0, Math.floor(drink.stock * salesFactor))
      const purchased = Math.floor(Math.random() * 5)
      const openingStock = drink.stock
      const closingStock = openingStock + purchased - sold

      return {
        drinkId: drink.id,
        drinkName: drink.name,
        openingStock,
        purchased,
        sold,
        closingStock,
        revenue: sold * drink.price,
        cost: purchased * drink.cost
      }
    })

    const totalPurchase = lines.reduce((sum, l) => sum + l.cost, 0)
    const totalRevenue = lines.reduce((sum, l) => sum + l.revenue, 0)
    const totalCost = lines.reduce((sum, l) => sum + l.cost, 0)
    const totalProfit = totalRevenue - totalCost

    sessions.push({
      id: uid(),
      date: dateStr,
      label: dateLabel(dateStr),
      lines,
      totalPurchase,
      totalRevenue,
      totalCost,
      totalProfit,
      closed: true
    })
  }

  // Generate 5 sample expenses
  const expenseCategories: ExpenseCategory[] = ['Approvisionnement', 'Salaires', 'Loyer', 'Électricité/Eau', 'Transport']
  for (let i = 0; i < 5; i++) {
    const expenseDate = new Date()
    expenseDate.setDate(expenseDate.getDate() - Math.floor(Math.random() * 30))
    expenses.push({
      id: uid(),
      date: expenseDate.toISOString().split('T')[0],
      description: `Dépense ${expenseCategories[i]}`,
      category: expenseCategories[i],
      amount: Math.floor(Math.random() * 50000) + 10000
    })
  }

  return {
    drinks,
    sessions,
    expenses,
    settings: {
      barName: 'Mon Bar',
      currency: 'FCFA'
    }
  }
}

// ============================================================================
// REDUCER
// ============================================================================

const initialState: AppStore = {
  drinks: [],
  sessions: [],
  expenses: [],
  settings: { barName: 'Mon Bar', currency: 'FCFA' }
}

const reducer = (state: AppStore, action: Action): AppStore => {
  switch (action.type) {
    case 'LOAD':
      return action.payload
    case 'ADD_DRINK':
      return { ...state, drinks: [...state.drinks, action.payload] }
    case 'UPDATE_DRINK':
      return {
        ...state,
        drinks: state.drinks.map(d => d.id === action.payload.id ? action.payload : d)
      }
    case 'DELETE_DRINK':
      return {
        ...state,
        drinks: state.drinks.filter(d => d.id !== action.payload)
      }
    case 'CLOSE_SESSION':
      return {
        ...state,
        sessions: [...state.sessions, action.payload],
        drinks: state.drinks.map(drink => {
          const line = action.payload.lines.find(l => l.drinkId === drink.id)
          return line ? { ...drink, stock: line.closingStock } : drink
        })
      }
    case 'ADD_EXPENSE':
      return {
        ...state,
        expenses: [...state.expenses, action.payload]
      }
    case 'DELETE_EXPENSE':
      return {
        ...state,
        expenses: state.expenses.filter(e => e.id !== action.payload)
      }
    case 'UPDATE_SETTINGS':
      return {
        ...state,
        settings: { ...state.settings, ...action.payload }
      }
    case 'RESET_DATA':
      return generateSeedData()
    default:
      return state
  }
}

// ============================================================================
// TOAST CONTEXT
// ============================================================================

interface ToastContextValue {
  toast: (opts: Omit<Toast, 'id'>) => void
}

const ToastContext = React.createContext<ToastContextValue | null>(null)

const useToast = () => {
  const ctx = React.useContext(ToastContext)
  if (!ctx) throw new Error('useToast must be used within ToastProvider')
  return ctx
}

const ToastProvider: React.FC<{ children: React.ReactNode }> = ({ children }) => {
  const [toasts, setToasts] = useState<Toast[]>([])

  const toast = useCallback((opts: Omit<Toast, 'id'>) => {
    const id = uid()
    setToasts(prev => [...prev, { ...opts, id }])
    setTimeout(() => {
      setToasts(prev => prev.filter(t => t.id !== id))
    }, 3000)
  }, [])

  return (
    <ToastContext.Provider value={{ toast }}>
      {children}
      <div className="fixed bottom-20 md:bottom-4 right-4 z-50 flex flex-col gap-2">
        {toasts.map(t => (
          <div
            key={t.id}
            className={`
              px-4 py-3 rounded-lg shadow-lg text-sm font-medium
              animate-in slide-in-from-bottom-4 fade-in
              ${t.variant === 'success' ? 'bg-emerald-50 text-emerald-900 border border-emerald-200 dark:bg-emerald-950 dark:text-emerald-100 dark:border-emerald-800' : ''}
              ${t.variant === 'error' ? 'bg-rose-50 text-rose-900 border border-rose-200 dark:bg-rose-950 dark:text-rose-100 dark:border-rose-800' : ''}
              ${t.variant === 'info' ? 'bg-sky-50 text-sky-900 border border-sky-200 dark:bg-sky-950 dark:text-sky-100 dark:border-sky-800' : ''}
            `}
          >
            {t.message}
          </div>
        ))}
      </div>
    </ToastContext.Provider>
  )
}

// ============================================================================
// CUSTOM TOOLTIP FOR CHARTS
// ============================================================================

const CustomTooltip = ({ active, payload, label }: any) => {
  if (!active || !payload?.length) return null
  return (
    <div className="bg-card border border-border rounded-lg p-3 shadow-lg text-sm">
      <p className="font-medium mb-1">{label}</p>
      {payload.map((p: any, i: number) => (
        <p key={i} style={{ color: p.color }}>
          {p.name}: {fmt(p.value)}
        </p>
      ))}
    </div>
  )
}

// ============================================================================
// MAIN APP COMPONENT
// ============================================================================

export default function App() {
  const [state, dispatch] = useReducer(reducer, initialState)
  const [page, setPage] = useState<Page>('dashboard')
  const [darkMode, setDarkMode] = useState(false)

  // Load from localStorage
  useEffect(() => {
    const stored = localStorage.getItem('bartrack_v2')
    if (stored) {
      try {
        dispatch({ type: 'LOAD', payload: JSON.parse(stored) })
      } catch (e) {
        console.error('Failed to parse stored data', e)
        dispatch({ type: 'RESET_DATA' })
      }
    } else {
      dispatch({ type: 'RESET_DATA' })
    }
  }, [])

  // Save to localStorage
  useEffect(() => {
    const timer = setTimeout(() => {
      localStorage.setItem('bartrack_v2', JSON.stringify(state))
    }, 500)
    return () => clearTimeout(timer)
  }, [state])

  // Dark mode
  useEffect(() => {
    const mediaQuery = window.matchMedia('(prefers-color-scheme: dark)')
    setDarkMode(mediaQuery.matches)
    const handler = (e: MediaQueryListEvent) => setDarkMode(e.matches)
    mediaQuery.addEventListener('change', handler)
    return () => mediaQuery.removeEventListener('change', handler)
  }, [])

  useEffect(() => {
    if (darkMode) {
      document.documentElement.classList.add('dark')
    } else {
      document.documentElement.classList.remove('dark')
    }
  }, [darkMode])

  const navItems = [
    { id: 'dashboard' as Page, label: 'Tableau de bord', icon: LayoutDashboard },
    { id: 'inventory' as Page, label: 'Inventaire', icon: Package },
    { id: 'session' as Page, label: 'Session du jour', icon: ClipboardList },
    { id: 'trends' as Page, label: 'Tendances', icon: TrendingUp },
    { id: 'finances' as Page, label: 'Finances', icon: DollarSign },
    { id: 'expenses' as Page, label: 'Dépenses', icon: Coins },
  ]

  return (
    <ToastProvider>
      <div className="min-h-screen bg-background text-foreground">
        {/* Desktop Sidebar */}
        <aside className="hidden md:block fixed left-0 top-0 bottom-0 w-60 bg-card border-r border-border">
          <div className="p-6">
            <div className="flex items-center gap-2 mb-1">
              <span className="text-2xl">🍺</span>
              <h1 className="text-xl font-semibold tracking-tight">BarTrack</h1>
            </div>
            <p className="text-xs text-muted-foreground">{state.settings.barName} · {state.settings.currency}</p>
          </div>
          <Separator />
          <nav className="p-3">
            {navItems.map(item => {
              const Icon = item.icon
              return (
                <button
                  key={item.id}
                  onClick={() => setPage(item.id)}
                  className={`
                    w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                    ${page === item.id
                      ? 'bg-amber-50 text-amber-900 dark:bg-amber-950 dark:text-amber-100'
                      : 'text-muted-foreground hover:bg-muted hover:text-foreground'
                    }
                  `}
                >
                  <Icon className="w-4 h-4" />
                  {item.label}
                </button>
              )
            })}
          </nav>
          <div className="absolute bottom-0 left-0 right-0 p-3">
            <button
              onClick={() => setPage('settings')}
              className={`
                w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors
                ${page === 'settings'
                  ? 'bg-amber-50 text-amber-900 dark:bg-amber-950 dark:text-amber-100'
                  : 'text-muted-foreground hover:bg-muted hover:text-foreground'
                }
              `}
            >
              <Settings className="w-4 h-4" />
              Paramètres
            </button>
          </div>
        </aside>

        {/* Main Content */}
        <main className="md:ml-60 pb-20 md:pb-4">
          <div className="p-4 md:p-6 max-w-7xl mx-auto">
            {page === 'dashboard' && <DashboardScreen state={state} setPage={setPage} />}
            {page === 'inventory' && <InventoryScreen state={state} dispatch={dispatch} setPage={setPage} />}
            {page === 'session' && <SessionScreen state={state} dispatch={dispatch} />}
            {page === 'trends' && <TrendsScreen state={state} />}
            {page === 'finances' && <FinancesScreen state={state} />}
            {page === 'expenses' && <ExpensesScreen state={state} dispatch={dispatch} />}
            {page === 'add-drink' && <AddDrinkScreen dispatch={dispatch} setPage={setPage} />}
            {page === 'settings' && <SettingsScreen state={state} dispatch={dispatch} />}
          </div>
        </main>

        {/* Mobile Bottom Nav */}
        <nav className="md:hidden fixed bottom-0 left-0 right-0 bg-card border-t border-border safe-area-inset-bottom">
          <div className="grid grid-cols-5 h-16">
            {navItems.slice(0, 5).map(item => {
              const Icon = item.icon
              return (
                <button
                  key={item.id}
                  onClick={() => setPage(item.id)}
                  className={`
                    flex flex-col items-center justify-center gap-1 transition-colors
                    ${page === item.id ? 'text-amber-600 dark:text-amber-400' : 'text-muted-foreground'}
                  `}
                >
                  <Icon className="w-5 h-5" />
                  <span className="text-[10px] font-medium">{item.label.split(' ')[0]}</span>
                  {page === item.id && (
                    <div className="absolute top-0 left-1/2 -translate-x-1/2 w-1 h-1 rounded-full bg-amber-600 dark:bg-amber-400" />
                  )}
                </button>
              )
            })}
          </div>
        </nav>
      </div>
    </ToastProvider>
  )
}

// ============================================================================
// SCREEN COMPONENTS
// ============================================================================

// ----------------------------------------------------------------------------
// DASHBOARD
// ----------------------------------------------------------------------------

const DashboardScreen: React.FC<{ state: AppStore; setPage: (p: Page) => void }> = ({ state, setPage }) => {
  const todayStr = today()
  const todaySession = state.sessions.find(s => s.date === todayStr)
  const last7Days = state.sessions.slice(-7)
  const last14Days = state.sessions.slice(-14)

  const todayRevenue = todaySession?.totalRevenue ?? 0
  const yesterdayRevenue = state.sessions[state.sessions.length - 2]?.totalRevenue ?? 0
  const todayDelta = yesterdayRevenue > 0 ? ((todayRevenue - yesterdayRevenue) / yesterdayRevenue) * 100 : 0

  const last7Revenue = last7Days.reduce((sum, s) => sum + s.totalRevenue, 0)
  const last7Cost = last7Days.reduce((sum, s) => sum + s.totalCost, 0)
  const last7Expenses = state.expenses
    .filter(e => {
      const d = new Date(e.date)
      const weekAgo = new Date()
      weekAgo.setDate(weekAgo.getDate() - 7)
      return d >= weekAgo
    })
    .reduce((sum, e) => sum + e.amount, 0)
  const netProfit7 = last7Revenue - last7Cost - last7Expenses

  const unitsSold7 = last7Days.reduce((sum, s) => sum + s.lines.reduce((ls, l) => ls + l.sold, 0), 0)

  const alerts = state.drinks.filter(d => d.stock <= d.minStock)

  const chartData = last14Days.map(s => ({
    date: dateLabel(s.date),
    revenue: s.totalRevenue,
    profit: s.totalProfit
  }))

  const top5 = useMemo(() => {
    const drinkSales = state.drinks.map(drink => {
      const sold = last7Days.reduce((sum, s) => {
        const line = s.lines.find(l => l.drinkId === drink.id)
        return sum + (line?.sold ?? 0)
      }, 0)
      const revenue = sold * drink.price
      return { drink, sold, revenue }
    })
    return drinkSales.sort((a, b) => b.revenue - a.revenue).slice(0, 5)
  }, [state.drinks, last7Days])

  const recommendations = useMemo(() => {
    return state.drinks.map(drink => {
      const dailySales = last7Days.map(s => s.lines.find(l => l.drinkId === drink.id)?.sold ?? 0)
      const avgDaily = dailySales.reduce((a, b) => a + b, 0) / Math.max(1, dailySales.length)
      const daysOfStock = avgDaily > 0 ? drink.stock / avgDaily : 999
      const recommended = Math.max(0, Math.round(avgDaily * 3) - drink.stock)
      return { drink, avgDaily, daysOfStock, recommended, estimatedCost: recommended * drink.cost }
    })
      .filter(r => r.recommended > 0)
      .sort((a, b) => a.daysOfStock - b.daysOfStock)
      .slice(0, 8)
  }, [state.drinks, last7Days])

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-xl font-semibold tracking-tight mb-1">Tableau de bord</h1>
        <p className="text-sm text-muted-foreground">{dateLabel(todayStr)}</p>
      </div>

      {/* KPIs */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
        <Card>
          <CardContent className="p-4">
            <div className="flex items-start justify-between mb-2">
              <p className="text-xs uppercase tracking-wide text-muted-foreground">Revenu aujourd'hui</p>
              <DollarSign className="w-4 h-4 text-muted-foreground" />
            </div>
            <p className="text-2xl font-bold tabular-nums">{fmtCompact(todayRevenue)}</p>
            <div className="mt-1">
              <Badge variant={todayDelta >= 0 ? 'default' : 'destructive'} className="text-xs">
                {todayDelta >= 0 ? <ArrowUp className="w-3 h-3 mr-1" /> : <ArrowDown className="w-3 h-3 mr-1" />}
                {Math.abs(todayDelta).toFixed(0)}% vs hier
              </Badge>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <div className="flex items-start justify-between mb-2">
              <p className="text-xs uppercase tracking-wide text-muted-foreground">Profit net (7j)</p>
              <TrendingUp className="w-4 h-4 text-muted-foreground" />
            </div>
            <p className={`text-2xl font-bold tabular-nums ${netProfit7 >= 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
              {fmtCompact(netProfit7)}
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardContent className="p-4">
            <div className="flex items-start justify-between mb-2">
              <p className="text-xs uppercase tracking-wide text-muted-foreground">Unités vendues (7j)</p>
              <ShoppingCart className="w-4 h-4 text-muted-foreground" />
            </div>
            <p className="text-2xl font-bold tabular-nums">{unitsSold7}</p>
          </CardContent>
        </Card>

        <Card className="cursor-pointer hover:bg-muted/50 transition-colors" onClick={() => setPage('inventory')}>
          <CardContent className="p-4">
            <div className="flex items-start justify-between mb-2">
              <p className="text-xs uppercase tracking-wide text-muted-foreground">Alertes stock</p>
              <AlertTriangle className={`w-4 h-4 ${alerts.length > 0 ? 'text-rose-600' : 'text-muted-foreground'}`} />
            </div>
            <p className={`text-2xl font-bold tabular-nums ${alerts.length > 0 ? 'text-rose-600' : ''}`}>
              {alerts.length}
            </p>
          </CardContent>
        </Card>
      </div>

      {/* Revenue Chart */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Revenu (14 derniers jours)</CardTitle>
        </CardHeader>
        <CardContent>
          <ResponsiveContainer width="100%" height={200}>
            <AreaChart data={chartData} margin={{ top: 4, right: 4, bottom: 0, left: 0 }}>
              <defs>
                <linearGradient id="colorRevenue" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%" stopColor={COLORS.amber} stopOpacity={0.3} />
                  <stop offset="95%" stopColor={COLORS.amber} stopOpacity={0} />
                </linearGradient>
              </defs>
              <CartesianGrid strokeDasharray="3 3" stroke="#E2E8F0" vertical={false} />
              <XAxis dataKey="date" tick={{ fontSize: 11, fill: COLORS.slate }} />
              <YAxis tick={{ fontSize: 11, fill: COLORS.slate }} tickFormatter={fmtCompact} />
              <Tooltip content={<CustomTooltip />} />
              <Area type="monotone" dataKey="revenue" stroke={COLORS.amber} fill="url(#colorRevenue)" />
            </AreaChart>
          </ResponsiveContainer>
        </CardContent>
      </Card>

      {/* Top 5 */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Top 5 boissons (7j)</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="space-y-3">
            {top5.map((item, i) => (
              <div key={item.drink.id}>
                <div className="flex items-center justify-between mb-1">
                  <div className="flex items-center gap-2">
                    <span className="text-lg font-bold text-muted-foreground tabular-nums">{i + 1}</span>
                    <span className="text-sm font-medium">{item.drink.name}</span>
                  </div>
                  <span className="text-sm font-semibold text-amber-600">{fmt(item.revenue)}</span>
                </div>
                <div className="flex items-center gap-2">
                  <div className="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                    <div
                      className="h-full bg-amber-500 rounded-full"
                      style={{ width: `${(item.sold / top5[0].sold) * 100}%` }}
                    />
                  </div>
                  <span className="text-xs text-muted-foreground tabular-nums">{item.sold} unités</span>
                </div>
              </div>
            ))}
          </div>
        </CardContent>
      </Card>

      {/* Alerts */}
      {alerts.length > 0 ? (
        <Alert className="border-rose-200 bg-rose-50 dark:border-rose-800 dark:bg-rose-950">
          <AlertTriangle className="w-4 h-4 text-rose-600" />
          <AlertDescription>
            <p className="font-semibold text-rose-900 dark:text-rose-100 mb-2">
              {alerts.length} boisson(s) en alerte stock
            </p>
            <div className="space-y-1">
              {alerts.slice(0, 5).map(d => (
                <div key={d.id} className="text-sm text-rose-800 dark:text-rose-200">
                  {d.name}: {d.stock} unités (min: {d.minStock})
                </div>
              ))}
            </div>
          </AlertDescription>
        </Alert>
      ) : (
        <Alert className="border-emerald-200 bg-emerald-50 dark:border-emerald-800 dark:bg-emerald-950">
          <Check className="w-4 h-4 text-emerald-600" />
          <AlertDescription className="text-emerald-900 dark:text-emerald-100">
            Tous les stocks sont au-dessus du seuil d'alerte
          </AlertDescription>
        </Alert>
      )}

      {/* Recommendations */}
      {recommendations.length > 0 && (
        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-semibold">Recommandations commande</CardTitle>
          </CardHeader>
          <CardContent>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-3">
              {recommendations.map(r => (
                <div
                  key={r.drink.id}
                  className={`
                    p-3 rounded-lg border
                    ${r.daysOfStock < 1 ? 'border-rose-200 bg-rose-50 dark:border-rose-800 dark:bg-rose-950' : ''}
                    ${r.daysOfStock >= 1 && r.daysOfStock < 2 ? 'border-amber-200 bg-amber-50 dark:border-amber-800 dark:bg-amber-950' : ''}
                    ${r.daysOfStock >= 2 ? 'border-border bg-muted/50' : ''}
                  `}
                >
                  <div className="flex items-start justify-between mb-1">
                    <p className="font-medium text-sm">{r.drink.name}</p>
                    {r.daysOfStock < 1 && <AlertTriangle className="w-4 h-4 text-rose-600" />}
                  </div>
                  <p className="text-xs text-muted-foreground mb-2">
                    Stock: {r.drink.stock} · Moy. {r.avgDaily.toFixed(1)}/jour
                  </p>
                  <div className="flex items-center justify-between">
                    <Badge variant="outline" className="bg-amber-100 text-amber-900 border-amber-300 dark:bg-amber-950 dark:text-amber-100">
                      Commander: {r.recommended} unités
                    </Badge>
                    <span className="text-xs text-muted-foreground">{fmtCompact(r.estimatedCost)}</span>
                  </div>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      )}
    </div>
  )
}

// ----------------------------------------------------------------------------
// INVENTORY
// ----------------------------------------------------------------------------

const InventoryScreen: React.FC<{
  state: AppStore
  dispatch: React.Dispatch<Action>
  setPage: (p: Page) => void
}> = ({ state, dispatch, setPage }) => {
  const [search, setSearch] = useState('')
  const [categoryFilter, setCategoryFilter] = useState<string>('Tout')
  const [editingDrink, setEditingDrink] = useState<Drink | null>(null)
  const { toast } = useToast()

  const filtered = state.drinks.filter(d => {
    if (!d.name.toLowerCase().includes(search.toLowerCase())) return false
    if (categoryFilter !== 'Tout' && d.category !== categoryFilter) return false
    return true
  })

  const categories: (Category | 'Tout')[] = ['Tout', 'Bière', 'Soda', 'Jus', 'Eau', 'Vin', 'Autre']

  const handleSave = (drink: Drink) => {
    dispatch({ type: 'UPDATE_DRINK', payload: drink })
    setEditingDrink(null)
    toast({ message: 'Boisson mise à jour', variant: 'success' })
  }

  const handleDelete = (id: string) => {
    dispatch({ type: 'DELETE_DRINK', payload: id })
    setEditingDrink(null)
    toast({ message: 'Boisson supprimée', variant: 'success' })
  }

  return (
    <div className="space-y-4">
      <div className="flex items-center justify-between">
        <h1 className="text-xl font-semibold tracking-tight">Inventaire</h1>
        <Button onClick={() => setPage('add-drink')} className="bg-amber-600 hover:bg-amber-700">
          <Plus className="w-4 h-4 mr-2" />
          Ajouter
        </Button>
      </div>

      {/* Filters */}
      <div className="flex gap-2">
        <div className="relative flex-1">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
          <Input
            placeholder="Rechercher..."
            value={search}
            onChange={e => setSearch(e.target.value)}
            className="pl-9"
          />
        </div>
        <Select value={categoryFilter} onValueChange={setCategoryFilter}>
          <SelectTrigger className="w-32">
            <SelectValue />
          </SelectTrigger>
          <SelectContent>
            {categories.map(cat => (
              <SelectItem key={cat} value={cat}>{cat}</SelectItem>
            ))}
          </SelectContent>
        </Select>
      </div>

      {/* Tabs by category */}
      <Tabs value={categoryFilter} onValueChange={setCategoryFilter}>
        <TabsList className="w-full justify-start overflow-x-auto">
          {categories.map(cat => {
            const count = cat === 'Tout' ? state.drinks.length : state.drinks.filter(d => d.category === cat).length
            return (
              <TabsTrigger key={cat} value={cat} className="flex items-center gap-1">
                {cat}
                <Badge variant="secondary" className="ml-1 text-xs">{count}</Badge>
              </TabsTrigger>
            )
          })}
        </TabsList>
      </Tabs>

      {/* Desktop Table */}
      <div className="hidden md:block">
        <Card>
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>Nom</TableHead>
                <TableHead>Catégorie</TableHead>
                <TableHead>Stock</TableHead>
                <TableHead>Niveau</TableHead>
                <TableHead className="text-right">Prix vente</TableHead>
                <TableHead className="text-right">Coût</TableHead>
                <TableHead className="text-right">Marge %</TableHead>
                <TableHead className="text-right">Valeur stock</TableHead>
                <TableHead></TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {filtered.map(drink => {
                const margin = ((drink.price - drink.cost) / drink.price * 100).toFixed(0)
                const stockValue = drink.stock * drink.cost
                const status = getStockStatus(drink.stock, drink.minStock)
                return (
                  <TableRow key={drink.id}>
                    <TableCell className="font-medium">{drink.name}</TableCell>
                    <TableCell>
                      <Badge style={{ backgroundColor: getCategoryColor(drink.category) + '20', color: getCategoryColor(drink.category) }}>
                        {drink.category}
                      </Badge>
                    </TableCell>
                    <TableCell className="tabular-nums">{drink.stock}</TableCell>
                    <TableCell>
                      <div className="flex items-center gap-2">
                        <div className="w-16 h-2 bg-muted rounded-full overflow-hidden">
                          <div
                            className={`h-full rounded-full ${status === 'ok' ? 'bg-emerald-500' : status === 'medium' ? 'bg-amber-500' : 'bg-rose-500'}`}
                            style={{ width: `${getStockPct(drink.stock, drink.minStock)}%` }}
                          />
                        </div>
                        {status === 'rupture' && <Badge variant="destructive" className="text-xs">Rupture</Badge>}
                        {status === 'low' && <Badge variant="destructive" className="text-xs">Bas</Badge>}
                      </div>
                    </TableCell>
                    <TableCell className="text-right tabular-nums">{fmt(drink.price)}</TableCell>
                    <TableCell className="text-right tabular-nums">{fmt(drink.cost)}</TableCell>
                    <TableCell className="text-right tabular-nums font-semibold">{margin}%</TableCell>
                    <TableCell className="text-right tabular-nums">{fmt(stockValue)}</TableCell>
                    <TableCell>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => setEditingDrink(drink)}
                      >
                        <Edit2 className="w-4 h-4" />
                      </Button>
                    </TableCell>
                  </TableRow>
                )
              })}
            </TableBody>
          </Table>
        </Card>
      </div>

      {/* Mobile Cards */}
      <div className="md:hidden grid grid-cols-1 gap-3">
        {filtered.map(drink => {
          const status = getStockStatus(drink.stock, drink.minStock)
          const margin = ((drink.price - drink.cost) / drink.price * 100).toFixed(0)
          return (
            <Card key={drink.id} className="cursor-pointer hover:bg-muted/50 transition-colors" onClick={() => setEditingDrink(drink)}>
              <CardContent className="p-4">
                <div className="flex items-start justify-between mb-2">
                  <p className="font-medium">{drink.name}</p>
                  <Badge style={{ backgroundColor: getCategoryColor(drink.category) + '20', color: getCategoryColor(drink.category) }}>
                    {drink.category}
                  </Badge>
                </div>
                <div className="space-y-2">
                  <div className="flex items-center gap-2">
                    <div className="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                      <div
                        className={`h-full rounded-full ${status === 'ok' ? 'bg-emerald-500' : status === 'medium' ? 'bg-amber-500' : 'bg-rose-500'}`}
                        style={{ width: `${getStockPct(drink.stock, drink.minStock)}%` }}
                      />
                    </div>
                    <span className="text-sm font-semibold tabular-nums">{drink.stock}</span>
                    {(status === 'rupture' || status === 'low') && (
                      <Badge variant="destructive" className="text-xs">{status === 'rupture' ? 'Rupture' : 'Bas'}</Badge>
                    )}
                  </div>
                  <p className="text-sm text-muted-foreground">
                    {fmt(drink.price)} · coût {fmt(drink.cost)} · marge {margin}%
                  </p>
                </div>
              </CardContent>
            </Card>
          )
        })}
      </div>

      {/* Edit Dialog/Sheet */}
      {editingDrink && (
        <>
          {/* Desktop Dialog */}
          <Dialog open={!!editingDrink} onOpenChange={(open) => !open && setEditingDrink(null)}>
            <DialogContent className="hidden md:block">
              <EditDrinkForm drink={editingDrink} onSave={handleSave} onDelete={handleDelete} onCancel={() => setEditingDrink(null)} />
            </DialogContent>
          </Dialog>

          {/* Mobile Sheet */}
          <Sheet open={!!editingDrink} onOpenChange={(open) => !open && setEditingDrink(null)}>
            <SheetContent side="bottom" className="md:hidden">
              <EditDrinkForm drink={editingDrink} onSave={handleSave} onDelete={handleDelete} onCancel={() => setEditingDrink(null)} />
            </SheetContent>
          </Sheet>
        </>
      )}
    </div>
  )
}

const EditDrinkForm: React.FC<{
  drink: Drink
  onSave: (d: Drink) => void
  onDelete: (id: string) => void
  onCancel: () => void
}> = ({ drink, onSave, onDelete, onCancel }) => {
  const [form, setForm] = useState(drink)
  const [deleteConfirm, setDeleteConfirm] = useState('')

  const margin = ((form.price - form.cost) / form.price * 100).toFixed(0)
  const profitPerUnit = form.price - form.cost

  return (
    <div className="space-y-4">
      <div>
        <h2 className="text-lg font-semibold">Modifier {drink.name}</h2>
      </div>

      <div className="space-y-3">
        <div>
          <Label>Stock actuel</Label>
          <Input
            type="number"
            inputMode="numeric"
            value={form.stock}
            onChange={e => setForm({ ...form, stock: parseInt(e.target.value) || 0 })}
          />
        </div>

        <div>
          <Label>Stock minimum</Label>
          <Input
            type="number"
            inputMode="numeric"
            value={form.minStock}
            onChange={e => setForm({ ...form, minStock: parseInt(e.target.value) || 0 })}
          />
        </div>

        <div>
          <Label>Prix de vente (FCFA)</Label>
          <Input
            type="number"
            inputMode="numeric"
            value={form.price}
            onChange={e => setForm({ ...form, price: parseInt(e.target.value) || 0 })}
          />
        </div>

        <div>
          <Label>Coût d'achat (FCFA)</Label>
          <Input
            type="number"
            inputMode="numeric"
            value={form.cost}
            onChange={e => setForm({ ...form, cost: parseInt(e.target.value) || 0 })}
          />
        </div>

        <Card className="bg-amber-50 dark:bg-amber-950 border-amber-200 dark:border-amber-800">
          <CardContent className="p-3">
            <p className="text-sm font-semibold text-amber-900 dark:text-amber-100">
              Marge: {margin}% · Profit/unité: {fmt(profitPerUnit)}
            </p>
          </CardContent>
        </Card>
      </div>

      <div className="flex gap-2">
        <Button onClick={() => onSave(form)} className="flex-1 bg-amber-600 hover:bg-amber-700">
          Enregistrer
        </Button>
        <Button onClick={onCancel} variant="outline" className="flex-1">
          Annuler
        </Button>
      </div>

      <Separator />

      <div className="space-y-2">
        <Label className="text-rose-600">Zone de danger</Label>
        <p className="text-xs text-muted-foreground">
          Tapez le nom de la boisson pour confirmer la suppression
        </p>
        <Input
          placeholder={drink.name}
          value={deleteConfirm}
          onChange={e => setDeleteConfirm(e.target.value)}
        />
        <Button
          variant="destructive"
          className="w-full"
          disabled={deleteConfirm !== drink.name}
          onClick={() => onDelete(drink.id)}
        >
          <Trash2 className="w-4 h-4 mr-2" />
          Supprimer cette boisson
        </Button>
      </div>
    </div>
  )
}

// ----------------------------------------------------------------------------
// SESSION
// ----------------------------------------------------------------------------

const SessionScreen: React.FC<{
  state: AppStore
  dispatch: React.Dispatch<Action>
}> = ({ state, dispatch }) => {
  const { toast } = useToast()
  const todayStr = today()
  const [search, setSearch] = useState('')
  const [categoryFilter, setCategoryFilter] = useState<string>('Tout')
  const [showOnlyMovement, setShowOnlyMovement] = useState(false)
  const [sessionData, setSessionData] = useState<Record<string, { purchased: number; sold: number }>>({})
  const [closeConfirmOpen, setCloseConfirmOpen] = useState(false)

  const categories: (Category | 'Tout')[] = ['Tout', 'Bière', 'Soda', 'Jus', 'Eau', 'Vin', 'Autre']

  const filtered = state.drinks.filter(d => {
    if (!d.name.toLowerCase().includes(search.toLowerCase())) return false
    if (categoryFilter !== 'Tout' && d.category !== categoryFilter) return false
    if (showOnlyMovement) {
      const data = sessionData[d.id]
      if (!data || (data.purchased === 0 && data.sold === 0)) return false
    }
    return true
  })

  const updateDrink = (drinkId: string, field: 'purchased' | 'sold', value: number) => {
    setSessionData(prev => ({
      ...prev,
      [drinkId]: {
        purchased: field === 'purchased' ? value : prev[drinkId]?.purchased ?? 0,
        sold: field === 'sold' ? value : prev[drinkId]?.sold ?? 0
      }
    }))
  }

  const totalRevenue = useMemo(() => {
    return state.drinks.reduce((sum, drink) => {
      const sold = sessionData[drink.id]?.sold ?? 0
      return sum + sold * drink.price
    }, 0)
  }, [sessionData, state.drinks])

  const totalPurchaseCost = useMemo(() => {
    return state.drinks.reduce((sum, drink) => {
      const purchased = sessionData[drink.id]?.purchased ?? 0
      return sum + purchased * drink.cost
    }, 0)
  }, [sessionData, state.drinks])

  const estimatedProfit = totalRevenue - totalPurchaseCost

  const handleCloseSession = () => {
    const lines: SessionLine[] = state.drinks.map(drink => {
      const data = sessionData[drink.id] ?? { purchased: 0, sold: 0 }
      const openingStock = drink.stock
      const closingStock = openingStock + data.purchased - data.sold
      return {
        drinkId: drink.id,
        drinkName: drink.name,
        openingStock,
        purchased: data.purchased,
        sold: data.sold,
        closingStock,
        revenue: data.sold * drink.price,
        cost: data.purchased * drink.cost
      }
    })

    const session: DailySession = {
      id: uid(),
      date: todayStr,
      label: dateLabel(todayStr),
      lines,
      totalPurchase: totalPurchaseCost,
      totalRevenue,
      totalCost: totalPurchaseCost,
      totalProfit: estimatedProfit,
      closed: true
    }

    dispatch({ type: 'CLOSE_SESSION', payload: session })
    setSessionData({})
    setCloseConfirmOpen(false)
    toast({ message: 'Session clôturée avec succès', variant: 'success' })
  }

  const negativeStockDrinks = state.drinks.filter(drink => {
    const data = sessionData[drink.id] ?? { purchased: 0, sold: 0 }
    return drink.stock + data.purchased - data.sold < 0
  })

  return (
    <div className="space-y-4">
      {/* Header */}
      <Card className="bg-gradient-to-br from-amber-50 to-amber-100 dark:from-amber-950 dark:to-amber-900 border-amber-200 dark:border-amber-800">
        <CardContent className="p-4">
          <div className="flex items-start justify-between mb-3">
            <div>
              <p className="text-sm text-muted-foreground">{dateLabel(todayStr)}</p>
              <Badge className="mt-1 bg-amber-600 text-white">Session ouverte</Badge>
            </div>
            <ClipboardList className="w-6 h-6 text-amber-600" />
          </div>
          <div>
            <p className="text-xs uppercase tracking-wide text-muted-foreground mb-1">Revenu en cours</p>
            <p className="text-3xl font-bold text-amber-900 dark:text-amber-100 tabular-nums">{fmt(totalRevenue)}</p>
          </div>
        </CardContent>
      </Card>

      {/* Filters */}
      <div className="flex gap-2">
        <div className="relative flex-1">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-muted-foreground" />
          <Input
            placeholder="Rechercher..."
            value={search}
            onChange={e => setSearch(e.target.value)}
            className="pl-9"
          />
        </div>
        <Select value={categoryFilter} onValueChange={setCategoryFilter}>
          <SelectTrigger className="w-32">
            <SelectValue />
          </SelectTrigger>
          <SelectContent>
            {categories.map(cat => (
              <SelectItem key={cat} value={cat}>{cat}</SelectItem>
            ))}
          </SelectContent>
        </Select>
      </div>

      <div className="flex items-center gap-2">
        <input
          type="checkbox"
          id="movement"
          checked={showOnlyMovement}
          onChange={e => setShowOnlyMovement(e.target.checked)}
          className="rounded border-gray-300"
        />
        <Label htmlFor="movement" className="text-sm cursor-pointer">Avec mouvement seulement</Label>
      </div>

      {/* Drink Steppers */}
      <div className="space-y-3">
        {filtered.map(drink => {
          const data = sessionData[drink.id] ?? { purchased: 0, sold: 0 }
          const closingStock = drink.stock + data.purchased - data.sold
          const lineRevenue = data.sold * drink.price

          return (
            <Card key={drink.id} className="overflow-hidden">
              <CardContent className="p-4">
                <div className="flex items-start justify-between mb-3">
                  <div>
                    <p className="font-medium">{drink.name}</p>
                    <p className="text-xs text-muted-foreground">
                      Stock départ: {drink.stock} · Prix: {fmt(drink.price)}
                    </p>
                  </div>
                  <Badge style={{ backgroundColor: getCategoryColor(drink.category) + '20', color: getCategoryColor(drink.category) }}>
                    {drink.category}
                  </Badge>
                </div>

                <div className="space-y-3">
                  {/* Purchased */}
                  <div>
                    <Label className="text-xs text-muted-foreground mb-1.5 block">Achats</Label>
                    <div className="flex items-center gap-2">
                      <Button
                        variant="outline"
                        className="h-11 w-11 rounded-xl text-rose-600 hover:text-rose-700 hover:bg-rose-50 active:scale-95 transition-transform"
                        onClick={() => updateDrink(drink.id, 'purchased', Math.max(0, data.purchased - 1))}
                      >
                        <Minus className="w-5 h-5" />
                      </Button>
                      <Input
                        type="number"
                        inputMode="numeric"
                        value={data.purchased}
                        onChange={e => updateDrink(drink.id, 'purchased', parseInt(e.target.value) || 0)}
                        className="text-center font-bold text-lg w-16 h-11"
                      />
                      <Button
                        className="h-11 w-11 rounded-xl bg-amber-500 text-white hover:bg-amber-600 active:scale-95 transition-transform"
                        onClick={() => updateDrink(drink.id, 'purchased', data.purchased + 1)}
                      >
                        <Plus className="w-5 h-5" />
                      </Button>
                    </div>
                  </div>

                  {/* Sold */}
                  <div>
                    <Label className="text-xs text-muted-foreground mb-1.5 block">Vendus</Label>
                    <div className="flex items-center gap-2">
                      <Button
                        variant="outline"
                        className="h-11 w-11 rounded-xl text-rose-600 hover:text-rose-700 hover:bg-rose-50 active:scale-95 transition-transform"
                        onClick={() => updateDrink(drink.id, 'sold', Math.max(0, data.sold - 1))}
                      >
                        <Minus className="w-5 h-5" />
                      </Button>
                      <Input
                        type="number"
                        inputMode="numeric"
                        value={data.sold}
                        onChange={e => updateDrink(drink.id, 'sold', parseInt(e.target.value) || 0)}
                        className="text-center font-bold text-lg w-16 h-11"
                      />
                      <Button
                        className="h-11 w-11 rounded-xl bg-amber-500 text-white hover:bg-amber-600 active:scale-95 transition-transform"
                        onClick={() => updateDrink(drink.id, 'sold', data.sold + 1)}
                      >
                        <Plus className="w-5 h-5" />
                      </Button>
                    </div>
                  </div>
                </div>

                <Separator className="my-3" />

                <div className="flex items-center justify-between text-sm">
                  <span className={`font-semibold ${closingStock < 0 ? 'text-rose-600' : ''}`}>
                    Restant: {closingStock}
                  </span>
                  <span className="font-semibold text-amber-600">
                    Ligne: {fmt(lineRevenue)}
                  </span>
                </div>
              </CardContent>
            </Card>
          )
        })}
      </div>

      {/* Floating Summary Bar */}
      <div className="fixed bottom-20 md:bottom-6 left-4 right-4 md:left-auto md:right-6 md:w-96 bg-card/95 backdrop-blur-md border border-border rounded-lg shadow-lg p-4">
        <div className="space-y-2 text-sm">
          <div className="flex items-center justify-between">
            <span className="text-muted-foreground">Achats totaux:</span>
            <span className="font-semibold tabular-nums">{fmt(totalPurchaseCost)}</span>
          </div>
          <div className="flex items-center justify-between">
            <span className="text-muted-foreground">Revenu total:</span>
            <span className="font-semibold tabular-nums text-amber-600">{fmt(totalRevenue)}</span>
          </div>
          <div className="flex items-center justify-between">
            <span className="text-muted-foreground">Profit estimé:</span>
            <span className={`font-semibold tabular-nums ${estimatedProfit >= 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
              {fmt(estimatedProfit)}
            </span>
          </div>
        </div>
        <Button
          className="w-full mt-3 bg-amber-600 hover:bg-amber-700"
          onClick={() => setCloseConfirmOpen(true)}
        >
          Clôturer la session
        </Button>
      </div>

      {/* Close Confirmation */}
      <Dialog open={closeConfirmOpen} onOpenChange={setCloseConfirmOpen}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Clôturer la session du {dateLabel(todayStr)}</DialogTitle>
          </DialogHeader>
          <div className="space-y-3">
            <div className="grid grid-cols-2 gap-2 text-sm">
              <div>
                <p className="text-muted-foreground">Achats totaux</p>
                <p className="font-semibold">{fmt(totalPurchaseCost)}</p>
              </div>
              <div>
                <p className="text-muted-foreground">Revenu total</p>
                <p className="font-semibold text-amber-600">{fmt(totalRevenue)}</p>
              </div>
              <div>
                <p className="text-muted-foreground">Profit estimé</p>
                <p className={`font-semibold ${estimatedProfit >= 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
                  {fmt(estimatedProfit)}
                </p>
              </div>
            </div>

            {negativeStockDrinks.length > 0 && (
              <Alert className="border-rose-200 bg-rose-50 dark:border-rose-800 dark:bg-rose-950">
                <AlertTriangle className="w-4 h-4 text-rose-600" />
                <AlertDescription className="text-rose-900 dark:text-rose-100">
                  <p className="font-semibold mb-1">Attention: stocks négatifs</p>
                  {negativeStockDrinks.map(d => {
                    const data = sessionData[d.id] ?? { purchased: 0, sold: 0 }
                    const closing = d.stock + data.purchased - data.sold
                    return (
                      <p key={d.id} className="text-sm">{d.name}: {closing}</p>
                    )
                  })}
                </AlertDescription>
              </Alert>
            )}
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setCloseConfirmOpen(false)}>Annuler</Button>
            <Button className="bg-amber-600 hover:bg-amber-700" onClick={handleCloseSession}>
              Confirmer et clôturer
            </Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  )
}

// ----------------------------------------------------------------------------
// TRENDS
// ----------------------------------------------------------------------------

const TrendsScreen: React.FC<{ state: AppStore }> = ({ state }) => {
  const [period, setPeriod] = useState<'7' | '30' | '90'>('7')

  const sessions = state.sessions.slice(-parseInt(period))

  const chartData = sessions.map(s => ({
    date: dateLabel(s.date),
    revenue: s.totalRevenue,
    profit: s.totalProfit
  }))

  const volumeData = useMemo(() => {
    return sessions.map(s => {
      const byCategory: Record<string, number> = {}
      s.lines.forEach(l => {
        const drink = state.drinks.find(d => d.id === l.drinkId)
        if (drink) {
          byCategory[drink.category] = (byCategory[drink.category] || 0) + l.sold
        }
      })
      return {
        date: dateLabel(s.date),
        ...byCategory
      }
    })
  }, [sessions, state.drinks])

  const drinkPerformance = useMemo(() => {
    const perf = state.drinks.map(drink => {
      const sold = sessions.reduce((sum, s) => {
        const line = s.lines.find(l => l.drinkId === drink.id)
        return sum + (line?.sold ?? 0)
      }, 0)
      const revenue = sold * drink.price
      const avgDaily = sold / Math.max(1, sessions.length)
      const rotation = avgDaily >= 8 ? 'Fort' : avgDaily >= 3 ? 'Moyen' : 'Lent'
      const trend = sold > 0 ? (Math.random() > 0.5 ? 'up' : 'down') : 'stable'
      return { drink, sold, revenue, avgDaily, rotation, trend }
    })
    return perf.sort((a, b) => b.revenue - a.revenue).slice(0, 20)
  }, [state.drinks, sessions])

  const revenueByCategory = useMemo(() => {
    const byCategory: Record<string, number> = {}
    sessions.forEach(s => {
      s.lines.forEach(l => {
        const drink = state.drinks.find(d => d.id === l.drinkId)
        if (drink) {
          byCategory[drink.category] = (byCategory[drink.category] || 0) + l.revenue
        }
      })
    })
    return Object.entries(byCategory).map(([name, value]) => ({ name, value }))
  }, [sessions, state.drinks])

  const volumeByCategory = useMemo(() => {
    const byCategory: Record<string, number> = {}
    sessions.forEach(s => {
      s.lines.forEach(l => {
        const drink = state.drinks.find(d => d.id === l.drinkId)
        if (drink) {
          byCategory[drink.category] = (byCategory[drink.category] || 0) + l.sold
        }
      })
    })
    return Object.entries(byCategory).map(([name, value]) => ({ name, value }))
  }, [sessions, state.drinks])

  const categories = ['Bière', 'Soda', 'Jus', 'Eau', 'Vin', 'Autre']

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-xl font-semibold tracking-tight">Tendances</h1>
      </div>

      {/* Period Selector */}
      <Tabs value={period} onValueChange={(v) => setPeriod(v as any)}>
        <TabsList>
          <TabsTrigger value="7">7 jours</TabsTrigger>
          <TabsTrigger value="30">30 jours</TabsTrigger>
          <TabsTrigger value="90">90 jours</TabsTrigger>
        </TabsList>
      </Tabs>

      {/* Revenue + Profit Chart */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Revenu & Profit</CardTitle>
        </CardHeader>
        <CardContent>
          <ResponsiveContainer width="100%" height={250}>
            <AreaChart data={chartData} margin={{ top: 4, right: 4, bottom: 0, left: 0 }}>
              <defs>
                <linearGradient id="colorRev" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%" stopColor={COLORS.amber} stopOpacity={0.3} />
                  <stop offset="95%" stopColor={COLORS.amber} stopOpacity={0} />
                </linearGradient>
                <linearGradient id="colorProf" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="5%" stopColor={COLORS.emerald} stopOpacity={0.3} />
                  <stop offset="95%" stopColor={COLORS.emerald} stopOpacity={0} />
                </linearGradient>
              </defs>
              <CartesianGrid strokeDasharray="3 3" stroke="#E2E8F0" vertical={false} />
              <XAxis dataKey="date" tick={{ fontSize: 11, fill: COLORS.slate }} />
              <YAxis tick={{ fontSize: 11, fill: COLORS.slate }} tickFormatter={fmtCompact} />
              <Tooltip content={<CustomTooltip />} />
              <Area type="monotone" dataKey="revenue" stroke={COLORS.amber} fill="url(#colorRev)" name="Revenu" />
              <Area type="monotone" dataKey="profit" stroke={COLORS.emerald} fill="url(#colorProf)" name="Profit" />
            </AreaChart>
          </ResponsiveContainer>
          <div className="flex items-center justify-center gap-4 mt-2 text-xs">
            <div className="flex items-center gap-1">
              <div className="w-3 h-3 rounded" style={{ backgroundColor: COLORS.amber }} />
              <span>Revenu</span>
            </div>
            <div className="flex items-center gap-1">
              <div className="w-3 h-3 rounded" style={{ backgroundColor: COLORS.emerald }} />
              <span>Profit</span>
            </div>
          </div>
        </CardContent>
      </Card>

      {/* Volume Chart */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Volume par catégorie</CardTitle>
        </CardHeader>
        <CardContent>
          <ResponsiveContainer width="100%" height={250}>
            <BarChart data={volumeData} margin={{ top: 4, right: 4, bottom: 0, left: 0 }}>
              <CartesianGrid strokeDasharray="3 3" stroke="#E2E8F0" vertical={false} />
              <XAxis dataKey="date" tick={{ fontSize: 11, fill: COLORS.slate }} />
              <YAxis tick={{ fontSize: 11, fill: COLORS.slate }} />
              <Tooltip content={<CustomTooltip />} />
              {categories.map(cat => (
                <Bar key={cat} dataKey={cat} stackId="a" fill={getCategoryColor(cat)} />
              ))}
            </BarChart>
          </ResponsiveContainer>
        </CardContent>
      </Card>

      {/* Performance Table */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Performance par boisson</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="space-y-2">
            {drinkPerformance.map((item, i) => (
              <div key={item.drink.id} className="flex items-center justify-between p-2 rounded hover:bg-muted/50">
                <div className="flex items-center gap-3 flex-1">
                  <span className="text-sm font-bold text-muted-foreground tabular-nums w-6">{i + 1}</span>
                  <div className="flex-1">
                    <p className="text-sm font-medium">{item.drink.name}</p>
                    <p className="text-xs text-muted-foreground">
                      {item.sold} unités · {item.avgDaily.toFixed(1)}/jour
                    </p>
                  </div>
                </div>
                <div className="flex items-center gap-2">
                  <Badge
                    variant="outline"
                    className={`text-xs ${item.rotation === 'Fort' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : item.rotation === 'Moyen' ? 'bg-amber-50 text-amber-700 border-amber-200' : 'bg-slate-50 text-slate-700 border-slate-200'}`}
                  >
                    {item.rotation}
                  </Badge>
                  {item.trend === 'up' && <ArrowUp className="w-4 h-4 text-emerald-600" />}
                  {item.trend === 'down' && <ArrowDown className="w-4 h-4 text-rose-600" />}
                  <span className="text-sm font-semibold text-amber-600 tabular-nums w-24 text-right">
                    {fmtCompact(item.revenue)}
                  </span>
                </div>
              </div>
            ))}
          </div>
        </CardContent>
      </Card>

      {/* Category Pies */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-semibold">Revenu par catégorie</CardTitle>
          </CardHeader>
          <CardContent>
            <ResponsiveContainer width="100%" height={200}>
              <PieChart>
                <Pie data={revenueByCategory} dataKey="value" nameKey="name" cx="50%" cy="50%" outerRadius={60}>
                  {revenueByCategory.map((entry, i) => (
                    <Cell key={i} fill={getCategoryColor(entry.name)} />
                  ))}
                </Pie>
                <Tooltip formatter={(value: number) => fmt(value)} />
              </PieChart>
            </ResponsiveContainer>
            <div className="flex flex-wrap gap-2 justify-center mt-2">
              {revenueByCategory.map(entry => (
                <div key={entry.name} className="flex items-center gap-1 text-xs">
                  <div className="w-3 h-3 rounded" style={{ backgroundColor: getCategoryColor(entry.name) }} />
                  <span>{entry.name}</span>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-semibold">Volume par catégorie</CardTitle>
          </CardHeader>
          <CardContent>
            <ResponsiveContainer width="100%" height={200}>
              <PieChart>
                <Pie data={volumeByCategory} dataKey="value" nameKey="name" cx="50%" cy="50%" outerRadius={60}>
                  {volumeByCategory.map((entry, i) => (
                    <Cell key={i} fill={getCategoryColor(entry.name)} />
                  ))}
                </Pie>
                <Tooltip />
              </PieChart>
            </ResponsiveContainer>
            <div className="flex flex-wrap gap-2 justify-center mt-2">
              {volumeByCategory.map(entry => (
                <div key={entry.name} className="flex items-center gap-1 text-xs">
                  <div className="w-3 h-3 rounded" style={{ backgroundColor: getCategoryColor(entry.name) }} />
                  <span>{entry.name}</span>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  )
}

// ----------------------------------------------------------------------------
// FINANCES
// ----------------------------------------------------------------------------

const FinancesScreen: React.FC<{ state: AppStore }> = ({ state }) => {
  const totalRevenue = state.sessions.reduce((sum, s) => sum + s.totalRevenue, 0)
  const totalSessionCost = state.sessions.reduce((sum, s) => sum + s.totalCost, 0)
  const totalExpenses = state.expenses.reduce((sum, e) => sum + e.amount, 0)
  const totalCost = totalSessionCost + totalExpenses
  const netProfit = totalRevenue - totalCost
  const margin = totalRevenue > 0 ? (netProfit / totalRevenue) * 100 : 0

  const dailyPL = useMemo(() => {
    return state.sessions.slice(-30).map(s => {
      const dayExpenses = state.expenses
        .filter(e => e.date === s.date)
        .reduce((sum, e) => sum + e.amount, 0)
      const profit = s.totalProfit - dayExpenses
      return {
        date: dateLabel(s.date),
        profit
      }
    })
  }, [state.sessions, state.expenses])

  const revenueByCategory = useMemo(() => {
    const byCategory: Record<string, number> = {}
    state.sessions.forEach(s => {
      s.lines.forEach(l => {
        const drink = state.drinks.find(d => d.id === l.drinkId)
        if (drink) {
          byCategory[drink.category] = (byCategory[drink.category] || 0) + l.revenue
        }
      })
    })
    return Object.entries(byCategory).map(([name, value]) => ({
      name,
      value,
      pct: totalRevenue > 0 ? ((value / totalRevenue) * 100).toFixed(1) : '0'
    }))
  }, [state.sessions, state.drinks, totalRevenue])

  const expenseByCategory = useMemo(() => {
    const byCategory: Record<string, number> = {}
    state.expenses.forEach(e => {
      byCategory[e.category] = (byCategory[e.category] || 0) + e.amount
    })
    return Object.entries(byCategory).map(([name, value]) => ({
      name,
      value,
      pct: totalExpenses > 0 ? ((value / totalExpenses) * 100).toFixed(1) : '0'
    }))
  }, [state.expenses, totalExpenses])

  const recentTransactions = useMemo(() => {
    const txns: Array<{ id: string; date: string; type: 'income' | 'expense'; description: string; amount: number }> = []

    state.sessions.forEach(s => {
      txns.push({
        id: s.id,
        date: s.date,
        type: 'income',
        description: `Revenu ${s.label}`,
        amount: s.totalRevenue
      })
    })

    state.expenses.forEach(e => {
      txns.push({
        id: e.id,
        date: e.date,
        type: 'expense',
        description: e.description,
        amount: e.amount
      })
    })

    return txns.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).slice(0, 20)
  }, [state.sessions, state.expenses])

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-xl font-semibold tracking-tight">Finances</h1>
      </div>

      {/* Hero Metric */}
      <Card className={`border-2 ${netProfit >= 0 ? 'border-emerald-200 dark:border-emerald-800' : 'border-rose-200 dark:border-rose-800'}`}>
        <CardContent className="p-6 text-center">
          <p className="text-xs uppercase tracking-wide text-muted-foreground mb-2">Profit net total</p>
          <p className={`text-4xl font-bold tabular-nums mb-3 ${netProfit >= 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
            {fmt(netProfit)}
          </p>
          <div className="max-w-xs mx-auto">
            <div className="h-2 bg-muted rounded-full overflow-hidden">
              <div
                className={`h-full ${margin >= 20 ? 'bg-emerald-500' : margin >= 10 ? 'bg-amber-500' : 'bg-rose-500'}`}
                style={{ width: `${Math.min(100, Math.max(0, margin))}%` }}
              />
            </div>
            <p className="text-xs text-muted-foreground mt-1">Marge: {margin.toFixed(1)}%</p>
          </div>
        </CardContent>
      </Card>

      {/* KPIs */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
        <Card>
          <CardContent className="p-4">
            <p className="text-xs uppercase tracking-wide text-muted-foreground mb-1">Revenu total</p>
            <p className="text-2xl font-bold tabular-nums text-emerald-600">{fmtCompact(totalRevenue)}</p>
          </CardContent>
        </Card>
        <Card>
          <CardContent className="p-4">
            <p className="text-xs uppercase tracking-wide text-muted-foreground mb-1">Dépenses totales</p>
            <p className="text-2xl font-bold tabular-nums text-rose-600">{fmtCompact(totalCost)}</p>
          </CardContent>
        </Card>
        <Card>
          <CardContent className="p-4">
            <p className="text-xs uppercase tracking-wide text-muted-foreground mb-1">Profit net</p>
            <p className={`text-2xl font-bold tabular-nums ${netProfit >= 0 ? 'text-emerald-600' : 'text-rose-600'}`}>
              {fmtCompact(netProfit)}
            </p>
          </CardContent>
        </Card>
        <Card>
          <CardContent className="p-4">
            <p className="text-xs uppercase tracking-wide text-muted-foreground mb-1">Marge bénéficiaire</p>
            <p className="text-2xl font-bold tabular-nums">{margin.toFixed(1)}%</p>
          </CardContent>
        </Card>
      </div>

      {/* P&L Chart */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Profit & Perte (30 jours)</CardTitle>
        </CardHeader>
        <CardContent>
          <ResponsiveContainer width="100%" height={200}>
            <BarChart data={dailyPL} margin={{ top: 4, right: 4, bottom: 0, left: 0 }}>
              <CartesianGrid strokeDasharray="3 3" stroke="#E2E8F0" vertical={false} />
              <XAxis dataKey="date" tick={{ fontSize: 11, fill: COLORS.slate }} />
              <YAxis tick={{ fontSize: 11, fill: COLORS.slate }} tickFormatter={fmtCompact} />
              <Tooltip content={<CustomTooltip />} />
              <Bar dataKey="profit" fill={COLORS.emerald}>
                {dailyPL.map((entry, index) => (
                  <Cell key={`cell-${index}`} fill={entry.profit >= 0 ? COLORS.emerald : COLORS.rose} />
                ))}
              </Bar>
            </BarChart>
          </ResponsiveContainer>
        </CardContent>
      </Card>

      {/* Revenue Breakdown */}
      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-semibold">Revenu par catégorie</CardTitle>
          </CardHeader>
          <CardContent>
            <div className="space-y-2">
              {revenueByCategory.map(cat => (
                <div key={cat.name}>
                  <div className="flex items-center justify-between mb-1">
                    <span className="text-sm font-medium">{cat.name}</span>
                    <span className="text-sm font-semibold text-amber-600">{fmt(cat.value)}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <div className="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                      <div
                        className="h-full rounded-full"
                        style={{ width: `${cat.pct}%`, backgroundColor: getCategoryColor(cat.name) }}
                      />
                    </div>
                    <span className="text-xs text-muted-foreground tabular-nums w-10 text-right">{cat.pct}%</span>
                  </div>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle className="text-sm font-semibold">Dépenses par catégorie</CardTitle>
          </CardHeader>
          <CardContent>
            <div className="space-y-2">
              {expenseByCategory.map(cat => (
                <div key={cat.name}>
                  <div className="flex items-center justify-between mb-1">
                    <span className="text-sm font-medium">{cat.name}</span>
                    <span className="text-sm font-semibold text-rose-600">{fmt(cat.value)}</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <div className="flex-1 h-2 bg-muted rounded-full overflow-hidden">
                      <div
                        className="h-full bg-rose-500 rounded-full"
                        style={{ width: `${cat.pct}%` }}
                      />
                    </div>
                    <span className="text-xs text-muted-foreground tabular-nums w-10 text-right">{cat.pct}%</span>
                  </div>
                </div>
              ))}
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Recent Transactions */}
      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Transactions récentes</CardTitle>
        </CardHeader>
        <CardContent>
          <div className="space-y-2">
            {recentTransactions.map(txn => (
              <div key={txn.id} className="flex items-center justify-between p-2 rounded hover:bg-muted/50">
                <div className="flex items-center gap-3">
                  <div className={`w-2 h-2 rounded-full ${txn.type === 'income' ? 'bg-emerald-500' : 'bg-rose-500'}`} />
                  <div>
                    <p className="text-sm font-medium">{txn.description}</p>
                    <p className="text-xs text-muted-foreground">{dateLabel(txn.date)}</p>
                  </div>
                </div>
                <span className={`text-sm font-semibold tabular-nums ${txn.type === 'income' ? 'text-emerald-600' : 'text-rose-600'}`}>
                  {txn.type === 'income' ? '+' : '-'} {fmt(txn.amount)}
                </span>
              </div>
            ))}
          </div>
        </CardContent>
      </Card>
    </div>
  )
}

// ----------------------------------------------------------------------------
// EXPENSES
// ----------------------------------------------------------------------------

const ExpensesScreen: React.FC<{
  state: AppStore
  dispatch: React.Dispatch<Action>
}> = ({ state, dispatch }) => {
  const { toast } = useToast()
  const [addOpen, setAddOpen] = useState(false)
  const [form, setForm] = useState({
    date: today(),
    description: '',
    category: 'Autre' as ExpenseCategory,
    amount: 0
  })

  const thisMonth = new Date().getMonth()
  const thisYear = new Date().getFullYear()
  const monthExpenses = state.expenses.filter(e => {
    const d = new Date(e.date)
    return d.getMonth() === thisMonth && d.getFullYear() === thisYear
  })
  const monthTotal = monthExpenses.reduce((sum, e) => sum + e.amount, 0)

  const categories: ExpenseCategory[] = ['Approvisionnement', 'Salaires', 'Loyer', 'Électricité/Eau', 'Réparations', 'Transport', 'Autre']

  const byCategory = useMemo(() => {
    const map: Record<string, number> = {}
    monthExpenses.forEach(e => {
      map[e.category] = (map[e.category] || 0) + e.amount
    })
    return Object.entries(map).map(([name, value]) => ({ name, value }))
  }, [monthExpenses])

  const handleAdd = () => {
    if (!form.description || form.amount <= 0) {
      toast({ message: 'Veuillez remplir tous les champs', variant: 'error' })
      return
    }
    const expense: Expense = {
      id: uid(),
      ...form
    }
    dispatch({ type: 'ADD_EXPENSE', payload: expense })
    setForm({ date: today(), description: '', category: 'Autre', amount: 0 })
    setAddOpen(false)
    toast({ message: 'Dépense ajoutée', variant: 'success' })
  }

  const handleDelete = (id: string) => {
    dispatch({ type: 'DELETE_EXPENSE', payload: id })
    toast({ message: 'Dépense supprimée', variant: 'success' })
  }

  return (
    <div className="space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-xl font-semibold tracking-tight">Dépenses</h1>
          <p className="text-sm text-muted-foreground">Ce mois: {monthExpenses.length} entrées</p>
        </div>
        <Button onClick={() => setAddOpen(true)} className="bg-amber-600 hover:bg-amber-700">
          <Plus className="w-4 h-4 mr-2" />
          Ajouter
        </Button>
      </div>

      {/* Month Total */}
      <Card>
        <CardContent className="p-6 text-center">
          <p className="text-xs uppercase tracking-wide text-muted-foreground mb-1">Total ce mois</p>
          <p className="text-3xl font-bold tabular-nums text-rose-600">{fmt(monthTotal)}</p>
        </CardContent>
      </Card>

      {/* Category Summary */}
      <div className="flex flex-wrap gap-2">
        {byCategory.map(cat => (
          <Badge key={cat.name} variant="outline" className="px-3 py-1.5">
            {cat.name}: {fmtCompact(cat.value)}
          </Badge>
        ))}
      </div>

      {/* Expense List - Desktop */}
      <div className="hidden md:block">
        <Card>
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>Date</TableHead>
                <TableHead>Description</TableHead>
                <TableHead>Catégorie</TableHead>
                <TableHead className="text-right">Montant</TableHead>
                <TableHead></TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {state.expenses.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).map(expense => (
                <TableRow key={expense.id}>
                  <TableCell>{dateLabel(expense.date)}</TableCell>
                  <TableCell className="font-medium">{expense.description}</TableCell>
                  <TableCell>
                    <Badge variant="outline">{expense.category}</Badge>
                  </TableCell>
                  <TableCell className="text-right tabular-nums font-semibold text-rose-600">
                    {fmt(expense.amount)}
                  </TableCell>
                  <TableCell>
                    <Button variant="ghost" size="sm" onClick={() => handleDelete(expense.id)}>
                      <Trash2 className="w-4 h-4" />
                    </Button>
                  </TableCell>
                </TableRow>
              ))}
            </TableBody>
          </Table>
        </Card>
      </div>

      {/* Expense List - Mobile */}
      <div className="md:hidden space-y-2">
        {state.expenses.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()).map(expense => (
          <Card key={expense.id}>
            <CardContent className="p-4">
              <div className="flex items-start justify-between mb-2">
                <div>
                  <p className="font-medium">{expense.description}</p>
                  <p className="text-xs text-muted-foreground">{dateLabel(expense.date)}</p>
                </div>
                <Button variant="ghost" size="sm" onClick={() => handleDelete(expense.id)}>
                  <Trash2 className="w-4 h-4 text-rose-600" />
                </Button>
              </div>
              <div className="flex items-center justify-between">
                <Badge variant="outline">{expense.category}</Badge>
                <span className="text-sm font-semibold text-rose-600 tabular-nums">{fmt(expense.amount)}</span>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>

      {/* Add Dialog */}
      <Dialog open={addOpen} onOpenChange={setAddOpen}>
        <DialogContent>
          <DialogHeader>
            <DialogTitle>Ajouter une dépense</DialogTitle>
          </DialogHeader>
          <div className="space-y-3">
            <div>
              <Label>Date</Label>
              <Input
                type="date"
                value={form.date}
                onChange={e => setForm({ ...form, date: e.target.value })}
              />
            </div>
            <div>
              <Label>Description</Label>
              <Input
                value={form.description}
                onChange={e => setForm({ ...form, description: e.target.value })}
                placeholder="Ex: Achat boissons"
              />
            </div>
            <div>
              <Label>Catégorie</Label>
              <Select value={form.category} onValueChange={(v) => setForm({ ...form, category: v as ExpenseCategory })}>
                <SelectTrigger>
                  <SelectValue />
                </SelectTrigger>
                <SelectContent>
                  {categories.map(cat => (
                    <SelectItem key={cat} value={cat}>{cat}</SelectItem>
                  ))}
                </SelectContent>
              </Select>
            </div>
            <div>
              <Label>Montant (FCFA)</Label>
              <Input
                type="number"
                inputMode="numeric"
                value={form.amount}
                onChange={e => setForm({ ...form, amount: parseInt(e.target.value) || 0 })}
              />
            </div>
          </div>
          <DialogFooter>
            <Button variant="outline" onClick={() => setAddOpen(false)}>Annuler</Button>
            <Button onClick={handleAdd} className="bg-amber-600 hover:bg-amber-700">Ajouter</Button>
          </DialogFooter>
        </DialogContent>
      </Dialog>
    </div>
  )
}

// ----------------------------------------------------------------------------
// ADD DRINK
// ----------------------------------------------------------------------------

const AddDrinkScreen: React.FC<{
  dispatch: React.Dispatch<Action>
  setPage: (p: Page) => void
}> = ({ dispatch, setPage }) => {
  const { toast } = useToast()
  const [step, setStep] = useState(1)
  const [form, setForm] = useState({
    name: '',
    category: 'Autre' as Category,
    price: 0,
    cost: 0,
    stock: 0,
    minStock: 0,
    supplier: '',
    notes: ''
  })

  const categories: Category[] = ['Bière', 'Soda', 'Jus', 'Eau', 'Vin', 'Autre']

  const margin = form.price > 0 ? ((form.price - form.cost) / form.price * 100).toFixed(0) : '0'
  const profitPerUnit = form.price - form.cost

  const handleSave = () => {
    if (!form.name) {
      toast({ message: 'Le nom est requis', variant: 'error' })
      return
    }
    const drink: Drink = {
      id: uid(),
      ...form,
      name: form.name.toUpperCase(),
      active: true,
      createdAt: new Date().toISOString()
    }
    dispatch({ type: 'ADD_DRINK', payload: drink })
    toast({ message: 'Boisson ajoutée', variant: 'success' })
    setPage('inventory')
  }

  return (
    <div className="max-w-2xl mx-auto space-y-6">
      <div>
        <h1 className="text-xl font-semibold tracking-tight">Ajouter une boisson</h1>
        <div className="flex items-center gap-2 mt-3">
          {[1, 2, 3].map(s => (
            <div
              key={s}
              className={`h-1 flex-1 rounded-full ${s <= step ? 'bg-amber-600' : 'bg-muted'}`}
            />
          ))}
        </div>
      </div>

      <Card>
        <CardContent className="p-6">
          {step === 1 && (
            <div className="space-y-4">
              <div>
                <h2 className="font-semibold mb-4">Identité</h2>
              </div>
              <div>
                <Label>Nom *</Label>
                <Input
                  value={form.name}
                  onChange={e => setForm({ ...form, name: e.target.value })}
                  placeholder="Ex: COCA COLA"
                  onBlur={e => setForm({ ...form, name: e.target.value.toUpperCase() })}
                />
              </div>
              <div>
                <Label>Catégorie *</Label>
                <Select value={form.category} onValueChange={(v) => setForm({ ...form, category: v as Category })}>
                  <SelectTrigger>
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent>
                    {categories.map(cat => (
                      <SelectItem key={cat} value={cat}>
                        <div className="flex items-center gap-2">
                          <div className="w-3 h-3 rounded" style={{ backgroundColor: getCategoryColor(cat) }} />
                          {cat}
                        </div>
                      </SelectItem>
                    ))}
                  </SelectContent>
                </Select>
              </div>
            </div>
          )}

          {step === 2 && (
            <div className="space-y-4">
              <div>
                <h2 className="font-semibold mb-4">Tarification</h2>
              </div>
              <div>
                <Label>Prix de vente (FCFA) *</Label>
                <Input
                  type="number"
                  inputMode="numeric"
                  value={form.price}
                  onChange={e => setForm({ ...form, price: parseInt(e.target.value) || 0 })}
                />
              </div>
              <div>
                <Label>Coût d'achat (FCFA) *</Label>
                <Input
                  type="number"
                  inputMode="numeric"
                  value={form.cost}
                  onChange={e => setForm({ ...form, cost: parseInt(e.target.value) || 0 })}
                />
              </div>
              <Card className="bg-amber-50 dark:bg-amber-950 border-amber-200 dark:border-amber-800">
                <CardContent className="p-4">
                  <p className="text-sm font-semibold text-amber-900 dark:text-amber-100">
                    Marge: {margin}% · Profit par unité: {fmt(profitPerUnit)}
                  </p>
                </CardContent>
              </Card>
            </div>
          )}

          {step === 3 && (
            <div className="space-y-4">
              <div>
                <h2 className="font-semibold mb-4">Stock</h2>
              </div>
              <div>
                <Label>Stock initial *</Label>
                <Input
                  type="number"
                  inputMode="numeric"
                  value={form.stock}
                  onChange={e => setForm({ ...form, stock: parseInt(e.target.value) || 0 })}
                />
              </div>
              <div>
                <Label>Stock minimum / seuil d'alerte *</Label>
                <Input
                  type="number"
                  inputMode="numeric"
                  value={form.minStock}
                  onChange={e => setForm({ ...form, minStock: parseInt(e.target.value) || 0 })}
                />
                <p className="text-xs text-muted-foreground mt-1">
                  Vous serez alerté quand le stock descend à ce niveau
                </p>
              </div>
              <div>
                <Label>Fournisseur (optionnel)</Label>
                <Input
                  value={form.supplier}
                  onChange={e => setForm({ ...form, supplier: e.target.value })}
                  placeholder="Ex: Brasseries du Cameroun"
                />
              </div>
              <div>
                <Label>Notes (optionnel)</Label>
                <Input
                  value={form.notes}
                  onChange={e => setForm({ ...form, notes: e.target.value })}
                  placeholder="Ex: Bouteille 1 litre"
                />
              </div>
            </div>
          )}
        </CardContent>
      </Card>

      <div className="flex gap-2">
        {step > 1 && (
          <Button variant="outline" onClick={() => setStep(step - 1)}>
            Précédent
          </Button>
        )}
        {step < 3 ? (
          <Button className="flex-1 bg-amber-600 hover:bg-amber-700" onClick={() => setStep(step + 1)}>
            Suivant
          </Button>
        ) : (
          <Button className="flex-1 bg-amber-600 hover:bg-amber-700" onClick={handleSave}>
            Enregistrer
          </Button>
        )}
        <Button variant="outline" onClick={() => setPage('inventory')}>
          Annuler
        </Button>
      </div>
    </div>
  )
}

// ----------------------------------------------------------------------------
// SETTINGS
// ----------------------------------------------------------------------------

const SettingsScreen: React.FC<{
  state: AppStore
  dispatch: React.Dispatch<Action>
}> = ({ state, dispatch }) => {
  const { toast } = useToast()
  const [barName, setBarName] = useState(state.settings.barName)
  const [resetConfirm, setResetConfirm] = useState('')

  const handleSave = () => {
    dispatch({ type: 'UPDATE_SETTINGS', payload: { barName } })
    toast({ message: 'Paramètres enregistrés', variant: 'success' })
  }

  const handleReset = () => {
    if (resetConfirm !== 'RESET') return
    dispatch({ type: 'RESET_DATA' })
    setResetConfirm('')
    toast({ message: 'Données réinitialisées', variant: 'success' })
  }

  return (
    <div className="max-w-2xl mx-auto space-y-6">
      <div>
        <h1 className="text-xl font-semibold tracking-tight">Paramètres</h1>
      </div>

      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">Informations générales</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3">
          <div>
            <Label>Nom du bar</Label>
            <Input value={barName} onChange={e => setBarName(e.target.value)} />
          </div>
          <div>
            <Label>Devise</Label>
            <Input value={state.settings.currency} disabled />
          </div>
          <Button onClick={handleSave} className="bg-amber-600 hover:bg-amber-700">
            Enregistrer
          </Button>
        </CardContent>
      </Card>

      <Card className="border-rose-200 dark:border-rose-800">
        <CardHeader>
          <CardTitle className="text-sm font-semibold text-rose-600">Zone de danger</CardTitle>
        </CardHeader>
        <CardContent className="space-y-3">
          <p className="text-sm text-muted-foreground">
            Cette action supprimera toutes vos données et réinitialisera l'application.
            Tapez <strong>RESET</strong> pour confirmer.
          </p>
          <Input
            placeholder="RESET"
            value={resetConfirm}
            onChange={e => setResetConfirm(e.target.value)}
          />
          <Button
            variant="destructive"
            disabled={resetConfirm !== 'RESET'}
            onClick={handleReset}
          >
            Réinitialiser toutes les données
          </Button>
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle className="text-sm font-semibold">À propos</CardTitle>
        </CardHeader>
        <CardContent>
          <p className="text-sm text-muted-foreground">
            BarTrack v2.0 · Système de gestion d'inventaire pour bars
          </p>
        </CardContent>
      </Card>
    </div>
  )
}
