// ============================================================================
// CONSTANTS & TYPES
// ============================================================================

const COLORS = {
  amber: '#D97706',
  amberLight: '#FEF3C7',
  amberDark: '#92400E',
  emerald: '#059669',
  emeraldLight: '#D1FAE5',
  rose: '#E11D48',
  roseLight: '#FFE4E6',
  sky: '#0284C7',
  skyLight: '#E0F2FE',
  violet: '#7C3AED',
  violetLight: '#EDE9FE',
  slate: '#64748B',
  biere: '#D97706',
  soda: '#0284C7',
  jus: '#059669',
  eau: '#7C3AED',
  vin: '#E11D48',
  autre: '#64748B',
}

type Category = 'Bière' | 'Soda' | 'Jus' | 'Eau' | 'Vin' | 'Autre'
type ExpenseCategory = 'Approvisionnement' | 'Salaires' | 'Loyer' | 'Électricité/Eau' | 'Réparations' | 'Transport' | 'Autre'

interface Drink {
  id: string
  name: string
  category: Category
  price: number
  cost: number
  stock: number
  minStock: number
  supplier: string
  notes: string
  active: boolean
  createdAt: string
}

interface SessionLine {
  drinkId: string
  drinkName: string
  openingStock: number
  purchased: number
  sold: number
  closingStock: number
  revenue: number
  cost: number
}

interface DailySession {
  id: string
  date: string
  label: string
  lines: SessionLine[]
  totalPurchase: number
  totalRevenue: number
  totalCost: number
  totalProfit: number
  closed: boolean
}

interface Expense {
  id: string
  date: string
  description: string
  category: ExpenseCategory
  amount: number
}

interface AppStore {
  drinks: Drink[]
  sessions: DailySession[]
  expenses: Expense[]
  settings: {
    barName: string
    currency: string
  }
}

type Page = 'dashboard' | 'inventory' | 'session' | 'trends' | 'finances' | 'expenses' | 'add-drink' | 'settings'

type Action =
  | { type: 'LOAD'; payload: AppStore }
  | { type: 'ADD_DRINK'; payload: Drink }
  | { type: 'UPDATE_DRINK'; payload: Drink }
  | { type: 'DELETE_DRINK'; payload: string }
  | { type: 'CLOSE_SESSION'; payload: DailySession }
  | { type: 'ADD_EXPENSE'; payload: Expense }
  | { type: 'DELETE_EXPENSE'; payload: string }
  | { type: 'UPDATE_SETTINGS'; payload: Partial<AppStore['settings']> }
  | { type: 'RESET_DATA' }

interface Toast {
  id: string
  message: string
  variant: 'success' | 'error' | 'info'
}

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

const uid = () => Math.random().toString(36).slice(2) + Date.now().toString(36)

const fmt = (n: number) => Math.round(n).toLocaleString('fr-FR') + ' FCFA'

const fmtCompact = (n: number) => {
  if (n >= 1_000_000) return (n / 1_000_000).toFixed(1) + 'M FCFA'
  if (n >= 1_000) return Math.round(n / 1_000) + 'k FCFA'
  return Math.round(n) + ' FCFA'
}

const today = () => new Date().toISOString().split('T')[0]

const dateLabel = (iso: string) =>
  new Date(iso).toLocaleDateString('fr-FR', { weekday: 'short', day: 'numeric', month: 'short' })

const getCategoryColor = (cat: string): string => {
  const map: Record<string, string> = {
    'Bière': COLORS.biere,
    'Soda': COLORS.soda,
    'Jus': COLORS.jus,
    'Eau': COLORS.eau,
    'Vin': COLORS.vin,
    'Autre': COLORS.autre
  }
  return map[cat] ?? COLORS.slate
}

const getStockStatus = (stock: number, minStock: number) => {
  if (stock === 0) return 'rupture'
  if (stock <= minStock) return 'low'
  if (stock <= minStock * 1.5) return 'medium'
  return 'ok'
}

const getStockPct = (stock: number, minStock: number) =>
  Math.min(100, Math.round((stock / Math.max(stock, minStock * 2)) * 100))

