{
  "expo": {
    "name": "BarTrack",
    "slug": "bartrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563EB",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bartrack.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "package": "com.bartrack.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "output": "single",
      "template": "./web/index.html",
      "name": "BarTrack - Inventory Management",
      "shortName": "BarTrack",
      "lang": "fr",
      "scope": "/",
      "themeColor": "#5B8DC7",
      "backgroundColor": "#F8FAFC",
      "description": "Professional inventory management system for bars and restaurants",
      "orientation": "any",
      "dir": "ltr",
      "preferRelatedApplications": false,
      "display": "standalone"
    },
    "plugins": [
      "expo-font"
    ]
  }
}
